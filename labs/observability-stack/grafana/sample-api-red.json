{
  "__comment": "RED-method dashboard for sample-api. Import into Grafana and select a Prometheus datasource. Every panel reads the recording rules from solution/prometheus/rules/recording.rules.yml so the dashboard and the burn-rate alerts share one definition of each signal. Validated as JSON by 'python3 -m json.tool'.",
  "schemaVersion": 39,
  "title": "sample-api - RED + SLO burn",
  "uid": "sample-api-red",
  "tags": ["observability-stack", "RED", "SLO"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (R) - req/s",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_requests:rate5m{job=\"sample-api\"}",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error ratio (E) - % 5xx",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.006},
              {"color": "red", "value": 0.0144}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_requests_error_ratio:rate5m{job=\"sample-api\"}",
          "legendFormat": "5m error ratio"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency (D) - p50 / p99 seconds",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 0}},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_request_duration_seconds:p50{job=\"sample-api\"}",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_request_duration_seconds:p99{job=\"sample-api\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error budget burn rate (1h window, multiples of budget)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 6},
              {"color": "red", "value": 14.4}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_requests_error_ratio:rate1h{job=\"sample-api\"} / 0.001",
          "legendFormat": "burn rate (1h)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Current p99 latency",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "job:http_request_duration_seconds:p99{job=\"sample-api\"}"
        }
      ]
    }
  ]
}
