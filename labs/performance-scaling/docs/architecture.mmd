            p2["pod 2"]
            pN["pod N"]
        end
        hpa["HorizontalPodAutoscaler\nCPU 50% of request\nmin 1 / max 5"]
        dep["Deployment cpu-burner\nrequest cpu=100m"]
    end
    subgraph ksys["kube-system"]
        ms["metrics-server\n(--kubelet-insecure-tls)"]
    end

    k6 --> pf --> svc --> p1 & p2 & pN
    ms -- "scrapes kubelet CPU" --> pods
    hpa -- "reads CPU util via metrics API" --> ms
    hpa -- "scales replicas" --> dep
    dep -- "manages" --> pods
