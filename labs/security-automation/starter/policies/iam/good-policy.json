{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOneBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::acme-reports-prod",
        "arn:aws:s3:::acme-reports-prod/*"
      ]
    },
    {
      "Sid": "DescribeOwnInstance",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeTags"
      ],
      "Resource": "arn:aws:ec2:us-east-1:111122223333:instance/i-0abc123def4567890"
    },
    {
      "Sid": "DenyOutsideHomeRegion",
      "Effect": "Deny",
      "Action": "*",
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    }
  ]
}
